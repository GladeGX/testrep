                    cnt = 0  # Сбрасываем для новой главы
                    bg = story[cnt_chapter][cnt][2]
                    character = story[cnt_chapter][cnt][1]
                    text = story[cnt_chapter][cnt][0]
                    cnt += 1

                elif event.key == pygame.K_2:
                    # Обработка выбора 2
                    story[cnt_chapter][cnt - 1][3] = False
                    if cnt_chapter == 0:
                        cnt_chapter = 2
                    elif cnt_chapter == 1:
