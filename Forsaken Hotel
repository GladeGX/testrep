def line_transfer(start_text):
    words = start_text.split(' ')
    string = ''
    indent = 550
    for i in words:
        if font.size(string + i)[0] < max_px:
            string += i
            string += ' '
        else:
            string_ready = font.render(string,False,'White')
            screen.blit(string_ready, (360, indent))
            indent += 40
            string = ''
            string += i
            string += ' '
        string_ready = font.render(string,False,'White')
        screen.blit(string_ready, (360, indent))


